# Supabase connection details for one-off seeding/admin commands run via
# scripts/seed_supabase.sh — copy to .env.supabase (gitignored) and fill in
# real values from your Supabase project. Never commit the filled-in file.

# Database > Connection string > URI > Session pooler (port 5432)
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Storage > S3 Connection (NOT Settings > API — the service_role key will not work here)
SUPABASE_S3_ENDPOINT_URL=https://xxxx.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_PUBLIC_BUCKET=public
SUPABASE_PRIVATE_BUCKET=private

# Same values you'd use anywhere else — needed for migrate/createsuperuser to run
SECRET_KEY=
JWT_SECRET=
