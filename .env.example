SECRET_KEY=
JWT_SECRET=
DEBUG=True

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=

# ---- Celery / RabbitMQ ----
# Set ALWAYS_EAGER=False only where a worker process is running
# (docker compose runs one); True executes tasks inline in the request.
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_TASK_ALWAYS_EAGER=True

# ---- Redis cache (optional) ----
# Empty = in-process fallback cache. API_CACHE_TTL is seconds for
# public read endpoints (assets, categories, collections).
REDIS_URL=
API_CACHE_TTL=900

# ---- Live archive feed (pull_urithi) ----
# Endpoint details are secrets: fill these ONLY in your local .env /
# host environment, never commit real values.
URITHI_BASE_URL=
URITHI_LIST_PATH=
URITHI_ACK_PATH=
MIRROR_THUMBNAILS=True
# Flat KES price auto-applied to synced assets without a price
ASSET_DEFAULT_PRICE=1500.00

# ---- Email (order confirmations, password reset, email verification) ----
# Default is console (prints to the terminal, nothing actually sent) —
# fine for local dev. For real delivery via Gmail:
#   1. Turn on 2-Step Verification on the sending Google account.
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#      (a normal Gmail password will NOT work here — SMTP auth requires
#      the 16-character app password instead).
#   3. Uncomment the 5 lines below and fill EMAIL_USERNAME/EMAIL_PASSWORD.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=youraddress@gmail.com
# EMAIL_PASSWORD=<16-character app password>
# DEFAULT_FROM_EMAIL=youraddress@gmail.com

# ---- Production only (config/settings/production.py) ----
# Supabase Postgres connection string (Project Settings > Database > Connection string)
# DATABASE_URL=postgres://user:password@host:5432/postgres

# Supabase Storage, S3-compatible (Project Settings > Storage > S3 Connection)
# SUPABASE_S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
# SUPABASE_S3_REGION=us-east-1
# SUPABASE_S3_ACCESS_KEY_ID=
# SUPABASE_S3_SECRET_ACCESS_KEY=
# SUPABASE_PUBLIC_BUCKET=public
# SUPABASE_PRIVATE_BUCKET=private
